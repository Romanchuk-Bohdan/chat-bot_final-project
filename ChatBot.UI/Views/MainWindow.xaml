<Window x:Class="ChatBot.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ChatBot.UI.Converters"
        Title="Smart Assistant Bot" Height="500" Width="400"
        Background="#F5F5F5">

    <Window.Resources>
        <converters:BooleanToAlignmentConverter x:Key="BooleanToAlignmentConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox ItemsSource="{Binding Messages}" 
                 BorderThickness="0" 
                 Background="Transparent" 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="10" Padding="10" Margin="5" MaxWidth="300"
                            HorizontalAlignment="{Binding IsUser, Converter={StaticResource BooleanToAlignmentConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#E1F5FE"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                        <Setter Property="Background" Value="#DCF8C6"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="14" Foreground="#212121"/>
                            <TextBlock Text="{Binding Time}" FontSize="10" Foreground="Gray" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBox Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}" 
                     FontSize="14" Padding="8" VerticalContentAlignment="Center"/>
            
            <Button Grid.Column="1" Content="Надіслати" Width="90" Margin="8,0,0,0" 
                    Background="#2196F3" Foreground="White" FontWeight="Bold"
                    Click="SendMessage_Click" IsDefault="True"/>
        </Grid>
    </Grid>
</Window>